<?php

namespace App\Http\Controllers;

use App\Http\Traits\ApiResponse;
use App\Models\Consultation;
use App\Models\PatientPaymentCacheItem;
use App\Models\PatientItemPayment;
use App\Models\Patient;
use Carbon\Carbon;
use Illuminate\Http\Request;
use Illuminate\Http\Response;
use Illuminate\Support\Facades\DB;

class SalesManagementDashboardController extends Controller
{
    use ApiResponse;

    public function __invoke(Request $request)
    {
        try {
            $request->validate([
                'start_date' => 'sometimes|date_format:Y-m-d',
                'end_date' => 'sometimes|date_format:Y-m-d'
            ]);

            $user = $request->user();
            
            // Check access permissions
            if (!$user || (!$user->is_admin && !in_array($user->role, ['Sales Manager', 'Sales']) && !isset($user->privileges['sales_management']) && !isset($user->privileges['sales_center']))) {
                return $this->sendResponse(null, Response::HTTP_FORBIDDEN, 'Access denied');
            }
            
            // Default to today if no dates provided
            $start_date = $request->start_date ?? Carbon::today()->format('Y-m-d');
            $end_date = $request->end_date ?? Carbon::today()->format('Y-m-d');

            // Default allow: if user missing or role unspecified, do not restrict by clinic
            if (!$user || $user->is_admin) {
                $clinic_id = $request->clinic_id;
            } else {
                $clinic_id = $user->clinic_id ?? null;
            }

            $data = [
                'summary' => [
                    'total_sales' => 0,
                    'sales_today' => 0,
                    'total_revenue' => 0,
                    'total_transactions' => 0,
                    'average_transaction' => 0,
                    'total_discounts' => 0,
                    'items_sold' => 0,
                    'pending_prescriptions' => 0,
                    'conversion_rate' => 0,
                ],
                'statistics' => [
                    'sales_by_category' => [],
                    'sales_by_day' => [],
                    'sales_trend' => [],
                    'top_customers' => [],
                    'clients_consulted_vs_sales' => [],
                    'prescription_demand' => [],
                    'revenue_growth' => [],
                ],
            ];

            // Total sales from patient payments - Enhanced calculation
            try {
                $totalSalesQuery = PatientItemPayment::query()
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $start_date . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59')
                    ->where('amount', '>', 0);
                
                if ($clinic_id) {
                    $totalSalesQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $totalSales = $totalSalesQuery->sum('amount') ?? 0;
                $data['summary']['total_sales'] = $totalSales;
                $data['summary']['total_revenue'] = $totalSales;
            } catch (\Exception $e) {
                \Log::error('Error calculating total sales', ['error' => $e->getMessage()]);
                $data['summary']['total_sales'] = 0;
                $data['summary']['total_revenue'] = 0;
            }

            // Sales today
            try {
                $today = Carbon::today()->format('Y-m-d');
                $salesTodayQuery = PatientItemPayment::query()
                    ->whereNotNull('created_at')
                    ->whereDate('created_at', $today)
                    ->where('amount', '>', 0);
                
                if ($clinic_id) {
                    $salesTodayQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['summary']['sales_today'] = $salesTodayQuery->sum('amount') ?? 0;
            } catch (\Exception $e) {
                \Log::error('Error calculating sales today', ['error' => $e->getMessage()]);
                $data['summary']['sales_today'] = 0;
            }

            // Total transactions
            try {
                $transactionsQuery = PatientItemPayment::query()
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $start_date . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59')
                    ->where('amount', '>', 0);
                
                if ($clinic_id) {
                    $transactionsQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['summary']['total_transactions'] = $transactionsQuery->count();
            } catch (\Exception $e) {
                \Log::error('Error calculating total transactions', ['error' => $e->getMessage()]);
                $data['summary']['total_transactions'] = 0;
            }

            // Average transaction
            if ($data['summary']['total_transactions'] > 0) {
                $data['summary']['average_transaction'] = $data['summary']['total_sales'] / $data['summary']['total_transactions'];
            }

            // Items sold - Enhanced with better filtering
            try {
                $itemsSoldQuery = PatientPaymentCacheItem::query()
                    ->where('status', 'Served')
                    ->whereNotNull('served_at')
                    ->where('served_at', '>=', $start_date . ' 00:00:00')
                    ->where('served_at', '<=', $end_date . ' 23:59:59')
                    ->where('quantity', '>', 0);
                
                if ($clinic_id) {
                    $itemsSoldQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['summary']['items_sold'] = $itemsSoldQuery->sum('quantity') ?? 0;
            } catch (\Exception $e) {
                \Log::error('Error calculating items sold', ['error' => $e->getMessage()]);
                $data['summary']['items_sold'] = 0;
            }

            // Total discounts - Calculate from payment cache items
            try {
                $discountsQuery = PatientPaymentCacheItem::query()
                    ->where('status', 'Served')
                    ->whereNotNull('served_at')
                    ->where('served_at', '>=', $start_date . ' 00:00:00')
                    ->where('served_at', '<=', $end_date . ' 23:59:59')
                    ->where('discount_amount', '>', 0);
                
                if ($clinic_id) {
                    $discountsQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['summary']['total_discounts'] = $discountsQuery->sum('discount_amount') ?? 0;
            } catch (\Exception $e) {
                \Log::error('Error calculating total discounts', ['error' => $e->getMessage()]);
                $data['summary']['total_discounts'] = 0;
            }

            // Pending prescriptions - Count unserved items
            try {
                $pendingPrescriptionsQuery = PatientPaymentCacheItem::query()
                    ->where('status', '!=', 'Served')
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $start_date . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59');
                
                if ($clinic_id) {
                    $pendingPrescriptionsQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['summary']['pending_prescriptions'] = $pendingPrescriptionsQuery->count() ?? 0;
            } catch (\Exception $e) {
                \Log::error('Error calculating pending prescriptions', ['error' => $e->getMessage()]);
                $data['summary']['pending_prescriptions'] = 0;
            }

            // Sales by category - Enhanced with proper categorization
            try {
                $salesByCategoryQuery = PatientPaymentCacheItem::query()
                    ->selectRaw('
                        CASE 
                            WHEN item_name LIKE "%lens%" OR item_name LIKE "%spectacle%" THEN "Optical Products"
                            WHEN item_name LIKE "%medicine%" OR item_name LIKE "%drug%" THEN "Medicines"
                            WHEN item_name LIKE "%frame%" THEN "Frames"
                            WHEN item_name LIKE "%contact%" THEN "Contact Lenses"
                            WHEN item_name LIKE "%solution%" THEN "Solutions"
                            ELSE "Other Products"
                        END as category,
                        SUM(total_amount) as amount,
                        COUNT(*) as count
                    ')
                    ->where('status', 'Served')
                    ->whereNotNull('served_at')
                    ->where('served_at', '>=', $start_date . ' 00:00:00')
                    ->where('served_at', '<=', $end_date . ' 23:59:59')
                    ->where('total_amount', '>', 0)
                    ->groupBy('category')
                    ->orderBy('amount', 'desc');
                
                if ($clinic_id) {
                    $salesByCategoryQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['statistics']['sales_by_category'] = $salesByCategoryQuery->get()->toArray();
            } catch (\Exception $e) {
                \Log::error('Error calculating sales by category', ['error' => $e->getMessage()]);
                $data['statistics']['sales_by_category'] = [];
            }

            // Sales by day - Last 7 days trend
            try {
                $salesByDayQuery = PatientItemPayment::query()
                    ->selectRaw('DATE(created_at) as date, SUM(amount) as amount, COUNT(*) as transactions')
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', Carbon::parse($start_date)->subDays(6)->format('Y-m-d') . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59')
                    ->where('amount', '>', 0)
                    ->groupBy('date')
                    ->orderBy('date');
                
                if ($clinic_id) {
                    $salesByDayQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $salesByDayData = $salesByDayQuery->get()->toArray();
                $data['statistics']['sales_by_day'] = $salesByDayData;
                
                // Extract trend data for performance calculation
                $data['statistics']['sales_trend'] = array_column($salesByDayData, 'amount');
            } catch (\Exception $e) {
                \Log::error('Error calculating sales by day', ['error' => $e->getMessage()]);
                $data['statistics']['sales_by_day'] = [];
                $data['statistics']['sales_trend'] = [];
            }

            // Top customers - Enhanced with customer details
            try {
                $topCustomersQuery = PatientItemPayment::query()
                    ->selectRaw('
                        patient_id,
                        COUNT(*) as transaction_count,
                        SUM(amount) as total_amount,
                        AVG(amount) as avg_amount
                    ')
                    ->with(['patient:id,first_name,last_name,phone'])
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $start_date . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59')
                    ->where('amount', '>', 0)
                    ->groupBy('patient_id')
                    ->orderBy('total_amount', 'desc')
                    ->limit(10);
                
                if ($clinic_id) {
                    $topCustomersQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $topCustomersData = $topCustomersQuery->get()->toArray();
                
                // Format customer names
                $data['statistics']['top_customers'] = array_map(function($customer) {
                    return [
                        'customer_name' => ($customer['patient']['first_name'] ?? '') . ' ' . ($customer['patient']['last_name'] ?? ''),
                        'phone' => $customer['patient']['phone'] ?? '',
                        'transaction_count' => $customer['transaction_count'],
                        'total_amount' => $customer['total_amount'],
                        'avg_amount' => $customer['avg_amount'],
                    ];
                }, $topCustomersData);
            } catch (\Exception $e) {
                \Log::error('Error calculating top customers', ['error' => $e->getMessage()]);
                $data['statistics']['top_customers'] = [];
            }

            // Clients consulted vs sales conversion
            try {
                $consultedPatients = Consultation::query()
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $start_date . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59')
                    ->where('status', 'Consulted');
                
                if ($clinic_id) {
                    $consultedPatients->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $consultedCount = $consultedPatients->count();
                $salesTransactions = $data['summary']['total_transactions'];
                
                // Calculate conversion rate
                if ($consultedCount > 0) {
                    $data['summary']['conversion_rate'] = round(($salesTransactions / $consultedCount) * 100, 2);
                }
                
                // Create comparison data for chart
                $data['statistics']['clients_consulted_vs_sales'] = [
                    [
                        'period' => 'Consultations',
                        'count' => $consultedCount
                    ],
                    [
                        'period' => 'Sales',
                        'count' => $salesTransactions
                    ]
                ];
            } catch (\Exception $e) {
                \Log::error('Error calculating consultation vs sales', ['error' => $e->getMessage()]);
                $data['statistics']['clients_consulted_vs_sales'] = [];
            }

            // Prescription demand - Track prescription trends
            try {
                $prescriptionDemandQuery = PatientPaymentCacheItem::query()
                    ->selectRaw('DATE(created_at) as date, COUNT(*) as prescriptions, SUM(CASE WHEN status = "Served" THEN 1 ELSE 0 END) as served')
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', Carbon::parse($start_date)->subDays(6)->format('Y-m-d') . ' 00:00:00')
                    ->where('created_at', '<=', $end_date . ' 23:59:59')
                    ->groupBy('date')
                    ->orderBy('date');
                
                if ($clinic_id) {
                    $prescriptionDemandQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['statistics']['prescription_demand'] = $prescriptionDemandQuery->get()->toArray();
            } catch (\Exception $e) {
                \Log::error('Error calculating prescription demand', ['error' => $e->getMessage()]);
                $data['statistics']['prescription_demand'] = [];
            }

            // Revenue growth - Month over month comparison
            try {
                $currentMonth = Carbon::parse($start_date);
                $previousMonth = $currentMonth->copy()->subMonth();
                
                $currentMonthRevenue = PatientItemPayment::query()
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $currentMonth->startOfMonth()->format('Y-m-d') . ' 00:00:00')
                    ->where('created_at', '<=', $currentMonth->endOfMonth()->format('Y-m-d') . ' 23:59:59')
                    ->where('amount', '>', 0);
                
                $previousMonthRevenue = PatientItemPayment::query()
                    ->whereNotNull('created_at')
                    ->where('created_at', '>=', $previousMonth->startOfMonth()->format('Y-m-d') . ' 00:00:00')
                    ->where('created_at', '<=', $previousMonth->endOfMonth()->format('Y-m-d') . ' 23:59:59')
                    ->where('amount', '>', 0);
                
                if ($clinic_id) {
                    $currentMonthRevenue->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                    $previousMonthRevenue->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $currentRevenue = $currentMonthRevenue->sum('amount') ?? 0;
                $previousRevenue = $previousMonthRevenue->sum('amount') ?? 0;
                
                $growthRate = $previousRevenue > 0 ? round((($currentRevenue - $previousRevenue) / $previousRevenue) * 100, 2) : 0;
                
                $data['statistics']['revenue_growth'] = [
                    [
                        'period' => 'Previous Month',
                        'revenue' => $previousRevenue
                    ],
                    [
                        'period' => 'Current Month',
                        'revenue' => $currentRevenue,
                        'growth_rate' => $growthRate
                    ]
                ];
            } catch (\Exception $e) {
                \Log::error('Error calculating revenue growth', ['error' => $e->getMessage()]);
                $data['statistics']['revenue_growth'] = [];
            }

            return $this->successResponse($data, 'Sales management dashboard data retrieved successfully');
            
        } catch (\Exception $e) {
            \Log::error('Sales Management Dashboard Error', [
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            
            return $this->errorResponse('Failed to retrieve sales management dashboard data', Response::HTTP_INTERNAL_SERVER_ERROR);
        }
    }
}

            // Sales trend (last 7 days)
            $data['statistics']['sales_trend'] = [];
            for ($i = 6; $i >= 0; $i--) {
                $date = Carbon::now()->subDays($i)->format('Y-m-d');
                try {
                    $salesQuery = PatientItemPayment::query()
                        ->whereNotNull('created_at')
                        ->whereDate('created_at', $date)
                        ->where('amount', '>', 0);
                    
                    if ($clinic_id) {
                        $salesQuery->whereHas('creator', function ($q) use ($clinic_id) {
                            $q->where('clinic_id', $clinic_id);
                        });
                    }
                    
                    $sales = $salesQuery->sum('amount') ?? 0;
                } catch (\Exception $e) {
                    \Log::error('Error calculating sales trend for date', ['date' => $date, 'error' => $e->getMessage()]);
                    $sales = 0;
                }

                $data['statistics']['sales_trend'][] = [
                    'date' => $date,
                    'sales' => $sales
                ];
            }

            // Clients Consulted vs Successful Sales (daily breakdown for the period)
            $clientsConsultedVsSales = [];
            $currentDate = Carbon::parse($start_date);
            $endDate = Carbon::parse($end_date);
            
            while ($currentDate->lte($endDate)) {
                $dateStr = $currentDate->format('Y-m-d');
                
                // Clients consulted on this date
                try {
                    $clientsConsultedQuery = Consultation::query()
                        ->where('status', 'Consulted')
                        ->whereNotNull('created_at')
                        ->whereDate('created_at', $dateStr);
                    
                    if ($clinic_id) {
                        $clientsConsultedQuery->whereHas('payment_cache_item.creator', function ($q) use ($clinic_id) {
                            $q->where('clinic_id', $clinic_id);
                        });
                    }
                    
                    $clientsConsulted = $clientsConsultedQuery
                        ->distinct('payment_cache_item_id')
                        ->count('payment_cache_item_id');
                } catch (\Exception $e) {
                    \Log::error('Error calculating clients consulted for date', ['date' => $dateStr, 'error' => $e->getMessage()]);
                    $clientsConsulted = 0;
                }
                
                // Successful sales (payments made) on this date
                try {
                    $successfulSalesQuery = PatientItemPayment::query()
                        ->whereNotNull('created_at')
                        ->whereDate('created_at', $dateStr)
                        ->where('amount', '>', 0);
                    
                    if ($clinic_id) {
                        $successfulSalesQuery->whereHas('creator', function ($q) use ($clinic_id) {
                            $q->where('clinic_id', $clinic_id);
                        });
                    }
                    
                    $successfulSales = $successfulSalesQuery->count();
                } catch (\Exception $e) {
                    \Log::error('Error calculating successful sales for date', ['date' => $dateStr, 'error' => $e->getMessage()]);
                    $successfulSales = 0;
                }
                
                $clientsConsultedVsSales[] = [
                    'date' => $dateStr,
                    'clients_consulted' => $clientsConsulted,
                    'successful_sales' => $successfulSales,
                ];
                
                $currentDate->addDay();
            }
            
            $data['statistics']['clients_consulted_vs_sales'] = $clientsConsultedVsSales;

            // Prescription Demand (pharmacy items sold by date)
            $prescriptionDemand = [];
            $currentDate = Carbon::parse($start_date);
            $endDate = Carbon::parse($end_date);
            
            while ($currentDate->lte($endDate)) {
                $dateStr = $currentDate->format('Y-m-d');
                
                // Pharmacy items sold on this date
                try {
                    $pharmacyItemsQuery = PatientPaymentCacheItem::query()
                        ->whereHas('consultation_type', function ($query) {
                            $query->where('name', 'Pharmacy');
                        })
                        ->where('status', 'Served')
                        ->whereNotNull('served_at')
                        ->whereDate('served_at', $dateStr);
                    
                    if ($clinic_id) {
                        $pharmacyItemsQuery->whereHas('creator', function ($q) use ($clinic_id) {
                            $q->where('clinic_id', $clinic_id);
                        });
                    }
                    
                    $pharmacyItems = $pharmacyItemsQuery->sum('quantity') ?? 0;
                } catch (\Exception $e) {
                    \Log::error('Error calculating pharmacy items for date', ['date' => $dateStr, 'error' => $e->getMessage()]);
                    $pharmacyItems = 0;
                }
                
                $prescriptionDemand[] = [
                    'date' => $dateStr,
                    'quantity' => $pharmacyItems,
                ];
                
                $currentDate->addDay();
            }
            
            $data['statistics']['prescription_demand'] = $prescriptionDemand;

            // Sales by category
            try {
                $salesByCategoryQuery = PatientPaymentCacheItem::query()
                    ->where('status', 'Served')
                    ->whereNotNull('served_at')
                    ->where('served_at', '>=', $start_date . ' 00:00:00')
                    ->where('served_at', '<=', $end_date . ' 23:59:59');
                
                if ($clinic_id) {
                    $salesByCategoryQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['statistics']['sales_by_category'] = $salesByCategoryQuery
                    ->join('consultation_types', 'patient_payment_cache_items.consultation_type_id', '=', 'consultation_types.id')
                    ->select(
                        'consultation_types.name',
                        DB::raw('SUM(patient_payment_cache_items.unit_price * patient_payment_cache_items.quantity) as total_sales'),
                        DB::raw('SUM(patient_payment_cache_items.quantity) as total_quantity')
                    )
                    ->groupBy('consultation_types.id', 'consultation_types.name')
                    ->get()
                    ->map(function ($item) {
                        return [
                            'name' => $item->name,
                            'total_sales' => (float) $item->total_sales,
                            'total_quantity' => (int) $item->total_quantity,
                        ];
                    });
            } catch (\Exception $e) {
                \Log::error('Error calculating sales by category', ['error' => $e->getMessage()]);
                $data['statistics']['sales_by_category'] = [];
            }

            // Top customers
            try {
                $topCustomersQuery = PatientItemPayment::query()
                    ->whereNotNull('patient_item_payments.created_at')
                    ->where('patient_item_payments.created_at', '>=', $start_date . ' 00:00:00')
                    ->where('patient_item_payments.created_at', '<=', $end_date . ' 23:59:59')
                    ->where('patient_item_payments.amount', '>', 0);
                
                if ($clinic_id) {
                    $topCustomersQuery->whereHas('creator', function ($q) use ($clinic_id) {
                        $q->where('clinic_id', $clinic_id);
                    });
                }
                
                $data['statistics']['top_customers'] = $topCustomersQuery
                    ->join('patient_payment_cache_items', 'patient_payment_cache_items.item_payment_id', '=', 'patient_item_payments.id')
                    ->join('patient_payment_cache', 'patient_payment_cache_items.payment_cache_id', '=', 'patient_payment_cache.id')
                    ->join('patient_check_ins', 'patient_payment_cache.check_in_id', '=', 'patient_check_ins.id')
                    ->join('patients', 'patient_check_ins.patient_id', '=', 'patients.id')
                    ->whereNotNull('patients.id')
                    ->select(
                        'patients.id',
                        'patients.first_name',
                        'patients.last_name',
                        DB::raw('CONCAT(COALESCE(patients.first_name, ""), " ", COALESCE(patients.last_name, "")) as customer_name'),
                        DB::raw('SUM(patient_item_payments.amount) as total_paid')
                    )
                    ->groupBy('patients.id', 'patients.first_name', 'patients.last_name')
                    ->orderBy('total_paid', 'desc')
                    ->limit(5)
                    ->get()
                    ->map(function ($item) {
                        return [
                            'id' => $item->id,
                            'customer_name' => trim($item->customer_name ?? ($item->first_name . ' ' . $item->last_name)),
                            'total_paid' => (float) ($item->total_paid ?? 0),
                        ];
                    })
                    ->toArray();
            } catch (\Exception $e) {
                \Log::error('Error calculating top customers', ['error' => $e->getMessage()]);
                $data['statistics']['top_customers'] = [];
            }

            // Debug logging
            \Log::info('SalesManagementDashboard data', [
                'clinic_id' => $clinic_id,
                'start_date' => $start_date,
                'end_date' => $end_date,
                'user_id' => $user->id ?? null,
                'user_is_admin' => $user->is_admin ?? false,
                'total_sales' => $data['summary']['total_sales'],
                'sales_today' => $data['summary']['sales_today'],
                'total_transactions' => $data['summary']['total_transactions'],
                'average_transaction' => $data['summary']['average_transaction'],
                'items_sold' => $data['summary']['items_sold'],
                'sales_trend_count' => count($data['statistics']['sales_trend']),
                'clients_consulted_vs_sales_count' => count($data['statistics']['clients_consulted_vs_sales']),
                'prescription_demand_count' => count($data['statistics']['prescription_demand']),
                'sales_by_category_count' => count($data['statistics']['sales_by_category']),
                'top_customers_count' => count($data['statistics']['top_customers']),
            ]);

            return $this->sendResponse($data, Response::HTTP_OK, 'Sales Management Dashboard data retrieved successfully.');
        
        } catch (\Throwable $e) {
            \Log::error('SalesManagementDashboard failed', [
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            
            // Return safe default data instead of 500 error
            return $this->sendResponse([
                'summary' => [
                    'total_sales' => 0,
                    'sales_today' => 0,
                    'total_revenue' => 0,
                    'total_transactions' => 0,
                    'average_transaction' => 0,
                    'total_discounts' => 0,
                    'items_sold' => 0,
                ],
                'statistics' => [
                    'sales_by_category' => [],
                    'sales_by_day' => [],
                    'sales_trend' => [],
                    'top_customers' => [],
                    'clients_consulted_vs_sales' => [],
                    'prescription_demand' => [],
                ],
            ], Response::HTTP_OK, 'Dashboard data temporarily unavailable.');
        }
    }
}

