import React, { useState, useEffect } from 'react';
import {
  Box,
  Card,
  CardContent,
  CardHeader,
  Typography,
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Paper,
  CircularProgress,
  Alert,
  Button,
  IconButton,
  Tooltip,
  Chip,
  Grid,
  Avatar,
  LinearProgress,
} from '@mui/material';
import {
  Edit as EditIcon,
  Save as SaveIcon,
  Cancel as CancelIcon,
  TrendingUp as TrendingIcon,
  TrendingDown as TrendingDownIcon,
  TrendingFlat as TrendingFlatIcon,
  Phone as PhoneIcon,
  People as PeopleIcon,
  LocalActivityRounded as EventsIcon
} from '@mui/icons-material';
import InfoCard from '../../dashboard/InfoCard';
import { useFetch, useToast } from '../../../hooks';
import { numberFormat } from '../../../helpers';
import Page from '../../../components/Page';
import {
  green,
  orange,
  red,
  blue,
  purple,
  cyan,
  deepOrange
} from '@mui/material/colors';

const CRMPerformanceReportCard = ({ 
  user, 
  editable = false,
  refreshTrigger = null 
}) => {
  const [isEditing, setIsEditing] = useState(false);
  const [editedTargets, setEditedTargets] = useState({});
  const [loading, setLoading] = useState(false);
  const [data, setData] = useState(null);
  const addToast = useToast();
  const { patch } = usePatch();

  // Fetch CRM performance data
  const {
    data: performanceData,
    loading: performanceLoading,
    error: performanceError
  } = useFetch('/api/performance-reports/crm', {
    dependencies: [refreshTrigger]
  });

  useEffect(() => {
    if (performanceData) {
      console.log('CRM Performance Data:', performanceData);
      // Backend returns: {message, data: {...}} - we need the nested data
      if (performanceData.data) {
        setData(performanceData.data);
      }
    }
  }, [performanceData]);

  useEffect(() => {
    console.log('Data State:', data);
    console.log('Loading State:', performanceLoading);
    console.log('Error State:', performanceError);
  }, [data, performanceLoading, performanceError]);

  const handleEdit = () => {
    setIsEditing(true);
    const targets = {};
    if (data?.kpis) {
      data.kpis.forEach(kpi => {
        targets[kpi.id] = kpi.target;
      });
    }
    setEditedTargets(targets);
  };

  const handleCancel = () => {
    setIsEditing(false);
    setEditedTargets({});
  };

  const handleSave = async () => {
    setLoading(true);
    try {
      await patch('/api/performance-reports/crm/targets', {
        targets: editedTargets
      });
      
      // Refresh data
      window.location.reload();
      
      addToast({
        message: 'CRM targets updated successfully!',
        severity: 'success'
      });
    } catch (error) {
      addToast({
        message: 'Failed to update targets',
        severity: 'error'
      });
    } finally {
      setLoading(false);
      setIsEditing(false);
    }
  };

  const handleTargetChange = (kpiKey, value) => {
    setEditedTargets(prev => ({
      ...prev,
      [kpiKey]: parseFloat(value) || 0
    }));
  };

  const getIndicatorColor = (result, target) => {
    if (target === 0) return 'default';
    const percentage = (result / target) * 100;
    if (percentage < 100) return 'warning';
    if (percentage === 100) return 'success';
    return 'primary';
  };

  const getPerformanceColor = (result, target) => {
    if (target === 0) return '#gray';
    const percentage = (result / target) * 100;
    if (percentage < 100) return '#ff9800'; // Orange
    if (percentage === 100) return '#4caf50'; // Green
    return '#2196f3'; // Blue
  };

  if (performanceLoading) {
    console.log('Loading state - showing CircularProgress');
    return (
      <Box sx={{ display: 'flex', justifyContent: 'center', p: 4 }}>
        <CircularProgress />
      </Box>
    );
  }

  if (performanceError || !data) {
    console.log('Rendering CRM Report Card with data:', data);

  const getPerformanceColor = (result, target) => {
    if (target === 0) return '#gray';
    const percentage = (result / target) * 100;
    if (percentage < 100) return '#ff9800'; // Orange
    if (percentage === 100) return '#4caf50'; // Green
    return '#2196f3'; // Blue
  };

  return (
    <Page title="CRM Report Card">
      <Box sx={{ p: 3 }}>
        {/* Header */}
        <Card sx={{ mb: 3 }}>
          <CardHeader
            title="CRM Report Card"
            subheader={`Last updated: ${new Date().toLocaleDateString()}`}
            action={
              editable && !isEditing ? (
                <Tooltip title="Edit Targets">
                  <IconButton onClick={handleEdit}>
                    <EditIcon />
                  </IconButton>
                </Tooltip>
              ) : (
                <Box sx={{ display: 'flex', gap: 1 }}>
                  {isEditing && (
                    <>
                      <IconButton onClick={handleSave}>
                        <SaveIcon />
                      </IconButton>
                      <IconButton onClick={handleCancel}>
                        <CancelIcon />
                      </IconButton>
                    </>
                  )}
                </Box>
              )
            }
          />
        </Card>

        {/* Summary Cards */}
        <Grid container spacing={3} sx={{ mb: 3 }}>
          {data?.kpis?.map((kpi, index) => (
            <Grid item xs={12} sm={6} md={3} key={index}>
              <InfoCard
                title={kpi.name}
                count={kpi.formatted_result}
                icon={
                  kpi.id.includes('contact') ? <PhoneIcon /> :
                  kpi.id.includes('lead') ? <PeopleIcon /> :
                  <EventsIcon />
                }
                color={
                  kpi.id === 'called_contacts' ? green[500] :
                  kpi.id === 'marketing_glass_leads' ? blue[500] :
                  orange[500]
                }
                onClick={() => navigate('/crm-reports/performance-report-card')}
              />
            </Grid>
          ))}
        </Grid>

        {/* KPI Table */}
        <Card sx={{ mb: 3 }}>
          <CardContent>
            <TableContainer component={Paper}>
              <Table>
                <TableHead>
                  <TableRow>
                    <TableCell><strong>KPI</strong></TableCell>
                    <TableCell align="right"><strong>Target</strong></TableCell>
                    <TableCell align="right"><strong>Result</strong></TableCell>
                    <TableCell align="center"><strong>Indicator</strong></TableCell>
                  </TableRow>
                </TableHead>
                <TableBody>
                  {data?.kpis?.map((kpi, index) => (
                    <TableRow key={index}>
                      <TableCell>
                        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                          {kpi.id.includes('contact') && <PhoneIcon fontSize="small" />}
                          {kpi.id.includes('lead') && <PeopleIcon fontSize="small" />}
                          {kpi.name}
                        </Box>
                      </TableCell>
                      <TableCell align="right">
                        {isEditing ? (
                          <input
                            type="number"
                            value={editedTargets[kpi.id] || kpi.target}
                            onChange={(e) => handleTargetChange(kpi.id, e.target.value)}
                            style={{ 
                              width: '80px', 
                              padding: '4px', 
                              border: '1px solid #ccc',
                              borderRadius: '4px'
                            }}
                          />
                        ) : (
                          `${kpi.formatted_target} ${kpi.unit}`
                        )}
                      </TableCell>
                      <TableCell align="right">
                        {kpi.formatted_result} {kpi.unit}
                      </TableCell>
                      <TableCell align="center">
                        <Chip
                          label="●"
                          color={getIndicatorColor(kpi.result, kpi.target)}
                          sx={{
                            backgroundColor: getPerformanceColor(kpi.result, kpi.target),
                            color: 'white',
                            fontWeight: 'bold'
                          }}
                        />
                      </TableCell>
                    </TableRow>
                  </TableHead>
                  <TableBody>
                    {data?.kpis?.map((kpi, index) => (
                      <TableRow key={index}>
                    <TableCell>
                      <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                        {kpi.id.includes('contact') && <PhoneIcon fontSize="small" />}
                        {kpi.id.includes('lead') && <PeopleIcon fontSize="small" />}
                        {kpi.name}
                      </Box>
                    </TableCell>
                    <TableCell align="right">
                      {isEditing ? (
                        <input
                          type="number"
                          value={editedTargets[kpi.id] || kpi.target}
                          onChange={(e) => handleTargetChange(kpi.id, e.target.value)}
                          style={{ 
                            width: '80px', 
                            padding: '4px', 
                            border: '1px solid #ccc',
                            borderRadius: '4px'
                          }}
                        />
                      ) : (
                        `${kpi.formatted_target} ${kpi.unit}`
                      )}
                    </TableCell>
                    <TableCell align="right">
                      {kpi.formatted_result} {kpi.unit}
                    </TableCell>
                    <TableCell align="center">
                      <Chip
                        label="●"
                        color={getIndicatorColor(kpi.result, kpi.target)}
                        sx={{
                          backgroundColor: getPerformanceColor(kpi.result, kpi.target),
                          color: 'white',
                          fontWeight: 'bold'
                        }}
                      />
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </TableContainer>
        </CardContent>
      </Card>

      {/* Report Summary */}
      <Card sx={{ mb: 3 }}>
        <CardHeader title="Report Summary" />
        <CardContent>
          <Typography variant="body2">
            {data?.summary || 'Performance summary will be generated here.'}
          </Typography>
        </CardContent>
      </Card>

      {/* Report Recommendations */}
      <Card>
        <CardHeader title="Report Recommendations" />
        <CardContent>
          <Typography variant="body2">
            {data?.recommendations || 'Recommendations will appear here.'}
          </Typography>
        </CardContent>
      </Card>
    </Box>
  );
};

export default CRMPerformanceReportCard;
